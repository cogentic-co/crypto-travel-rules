{
  "countryCode": "TL",
  "name": "Timor-Leste",
  "authority": "Central Bank of Timor-Leste (BCTL)",
  "rules": [
    {
      "versionId": "TL-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "BCTL AML framework applies. Uses USD as official currency. No crypto-specific regulation."
      },
      "authorityUrl": "https://www.bancocentral.tl/",
      "sources": [
        { "label": "Anti-Money Laundering and Combating Terrorism Financing Law (Timor-Leste)", "url": "https://www.bancocentral.tl/" },
        { "label": "FATF - Timor-Leste (APG Mutual Evaluation)", "url": "https://www.fatf-gafi.org/en/countries/detail/Timor-Leste.html" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
