{
  "countryCode": "QA",
  "name": "Qatar",
  "authority": "Qatar Financial Centre Regulatory Authority (QFCRA)",
  "rules": [
    {
      "versionId": "QA-2024-001",
      "status": "active",
      "effectiveFrom": "2024-09-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 1000,
        "currency": "QAR",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "QFC Digital Assets Framework. Qatar Central Bank prohibits crypto for banks but QFCRA permits licensed digital asset services."
      },
      "authorityUrl": "https://www.qfcra.com/"
    }
  ]
}
