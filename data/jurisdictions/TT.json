{
  "countryCode": "TT",
  "name": "Trinidad and Tobago",
  "authority": "Central Bank of Trinidad and Tobago / Trinidad and Tobago Securities and Exchange Commission",
  "rules": [
    {
      "versionId": "TT-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 6800,
        "notes": "TTSEC and CBTT developing virtual asset framework. AML/CFT Act applies."
      },
      "authorityUrl": "https://www.central-bank.org.tt/",
      "sources": [
        { "label": "Central Bank of Trinidad and Tobago", "url": "https://www.central-bank.org.tt/" },
        { "label": "Proceeds of Crime Act - AML/CFT Framework", "url": "https://www.central-bank.org.tt/core-functions/aml-cft" },
        { "label": "CFATF - Trinidad and Tobago", "url": "https://www.cfatf-gafic.org/member-countries/trinidad-and-tobago" }
      ],
      "threshold": {
        "amount": 6800,
        "currency": "TTD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
