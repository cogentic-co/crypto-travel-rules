{
  "countryCode": "VC",
  "name": "Saint Vincent and the Grenadines",
  "authority": "ECCB / Financial Services Authority (FSA)",
  "rules": [
    {
      "versionId": "VC-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "ECCB member. FSA AML framework applies. Several crypto exchanges have registered here."
      },
      "authorityUrl": "https://www.eccb-centralbank.org/",
      "sources": [
        { "label": "Eastern Caribbean Central Bank (ECCB)", "url": "https://www.eccb-centralbank.org/" },
        { "label": "Proceeds of Crime and Money Laundering (Prevention) Act - SVG", "url": "https://svgfsa.com/" },
        { "label": "CFATF - St. Vincent and the Grenadines", "url": "https://www.cfatf-gafic.org/member-countries/st-vincent-and-the-grenadines" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "XCD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
