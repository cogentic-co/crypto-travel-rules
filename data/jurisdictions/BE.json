{
  "countryCode": "BE",
  "name": "Belgium",
  "authority": "Financial Services and Markets Authority (FSMA)",
  "rules": [
    {
      "versionId": "BE-2024-001",
      "status": "active",
      "effectiveFrom": "2024-12-30",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "FSMA enforces EU TFR for registered VASPs."
      },
      "authorityUrl": "https://www.fsma.be/en/virtual-currencies",
      "threshold": {
        "amount": 0,
        "currency": "EUR",
        "isZeroThreshold": true
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address",
          "dateOfBirth",
          "placeOfBirth",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "notes": "EU TFR (Regulation 2023/1113) applies zero threshold to all CASP-to-CASP crypto transfers from December 30, 2024. Originator must provide name, account number, and one of: address, ID document number, or date/place of birth (alternatives, not all mandatory simultaneously)."
    }
  ]
}
