{
  "countryCode": "JE",
  "name": "Jersey",
  "authority": "Jersey Financial Services Commission (JFSC)",
  "rules": [
    {
      "versionId": "JE-2024-001",
      "status": "active",
      "effectiveFrom": "2024-01-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "JFSC registers virtual currency exchanges. Proceeds of Crime (Jersey) Law applies."
      },
      "authorityUrl": "https://www.jerseyfsc.org/",
      "sources": [
        { "label": "Proceeds of Crime (Jersey) Law 1999 (as amended)", "url": "https://www.jerseyfsc.org/industry/financial-crime/" },
        { "label": "JFSC Virtual Currency Exchange Registration", "url": "https://www.jerseyfsc.org/industry/sectors/virtual-currency-exchange/" },
        { "label": "MONEYVAL – Jersey Mutual Evaluation", "url": "https://www.coe.int/en/web/moneyval/jurisdictions/jersey" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "GBP",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
