{
  "countryCode": "TR",
  "name": "Turkey",
  "authority": "Capital Markets Board of Turkey (SPK)",
  "rules": [
    {
      "versionId": "TR-2025-001",
      "status": "active",
      "effectiveFrom": "2025-02-25",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 15000,
        "notes": "SPK crypto asset regulation framework requires licensed platforms to comply with MASAK (FIU) travel rule. TC Kimlik No (national ID) required for Turkish originators."
      },
      "authorityUrl": "https://www.spk.gov.tr/",
      "sources": [
        { "label": "Capital Markets Board (SPK) Crypto Asset Regulation (Law No. 7518, 2024)", "url": "https://www.spk.gov.tr/" },
        { "label": "MASAK (FIU) AML/CFT Compliance Obligations", "url": "https://www.masak.gov.tr/en/" },
        { "label": "FATF – Turkey Mutual Evaluation", "url": "https://www.fatf-gafi.org/en/countries/detail/Turkiye.html" }
      ],
      "threshold": {
        "amount": 15000,
        "currency": "TRY",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
