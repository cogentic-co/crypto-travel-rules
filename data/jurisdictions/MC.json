{
  "countryCode": "MC",
  "name": "Monaco",
  "authority": "Commission de Contrôle des Activités Financières (CCAF)",
  "rules": [
    {
      "versionId": "MC-2025-001",
      "status": "active",
      "effectiveFrom": "2025-01-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "CCAF regulates digital asset service providers. Framework aligned with French/EU standards."
      },
      "authorityUrl": "https://ccaf.mc/en/",
      "sources": [
        { "label": "Monaco Law No. 1.549 on Digital Asset Service Providers", "url": "https://ccaf.mc/en/" },
        { "label": "MONEYVAL – Monaco Mutual Evaluation", "url": "https://www.coe.int/en/web/moneyval/jurisdictions/monaco" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "EUR",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
