{
  "countryCode": "EC",
  "name": "Ecuador",
  "authority": "Superintendencia de Bancos del Ecuador",
  "rules": [
    {
      "versionId": "EC-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "Ecuador uses USD. Central Bank has cautioned against crypto. AML framework applies."
      },
      "authorityUrl": "https://www.superbancos.gob.ec/",
      "sources": [
        { "label": "Superintendencia de Bancos del Ecuador", "url": "https://www.superbancos.gob.ec/" },
        { "label": "Ley Orgánica de Prevención, Detección y Erradicación del Delito de Lavado de Activos", "url": "https://www.uafe.gob.ec/" },
        { "label": "GAFILAT - Ecuador", "url": "https://www.gafilat.org/index.php/es/miembros/ecuador" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
