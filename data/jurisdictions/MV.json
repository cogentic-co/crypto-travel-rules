{
  "countryCode": "MV",
  "name": "Maldives",
  "authority": "Maldives Monetary Authority (MMA)",
  "rules": [
    {
      "versionId": "MV-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "MMA AML/CFT framework applies. No specific crypto regulation yet. Threshold in USD equivalent."
      },
      "authorityUrl": "https://www.mma.gov.mv/",
      "sources": [
        { "label": "Prevention of Money Laundering and Financing of Terrorism Act (Maldives)", "url": "https://www.mma.gov.mv/" },
        { "label": "FATF - Maldives (APG Mutual Evaluation)", "url": "https://www.fatf-gafi.org/en/countries/detail/Maldives.html" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
