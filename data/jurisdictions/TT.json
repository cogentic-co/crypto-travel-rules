{
  "countryCode": "TT",
  "name": "Trinidad and Tobago",
  "authority": "Central Bank of Trinidad and Tobago / Trinidad and Tobago Securities and Exchange Commission",
  "rules": [
    {
      "versionId": "TT-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 1000,
        "currency": "TTD",
        "isZeroThreshold": false
      },
      "requiredFields": {
