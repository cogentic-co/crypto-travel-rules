{
  "countryCode": "EC",
  "name": "Ecuador",
  "authority": "Superintendencia de Bancos del Ecuador",
  "rules": [
    {
      "versionId": "EC-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "Ecuador uses USD. Central Bank has cautioned against crypto. AML framework applies."
      },
      "authorityUrl": "https://www.superbancos.gob.ec/",
      "threshold": {
        "transmission": {
          "amount": 1000,
          "currency": "USD",
          "isZeroThreshold": false,
          "requiredFields": {
            "originator": [
              "fullName",
              "accountNumber",
              "idDocumentNumber"
            ],
            "beneficiary": [
              "fullName",
              "accountNumber"
            ]
          }
        },
        "verification": {
          "amount": 1000,
          "currency": "USD",
          "isZeroThreshold": false,
          "requiredFields": {
            "originator": [
              "fullName",
              "accountNumber",
              "idDocumentNumber"
            ],
            "beneficiary": [
              "fullName",
              "accountNumber"
            ]
          }
        }
      }
    }
  ]
}
