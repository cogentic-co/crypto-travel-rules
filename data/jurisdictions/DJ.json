{
  "countryCode": "DJ",
  "name": "Djibouti",
  "authority": "Banque Centrale de Djibouti",
  "rules": [
    {
      "versionId": "DJ-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "Central Bank AML/CFT framework applies. Uses Djiboutian franc pegged to USD."
      },
      "authorityUrl": "https://www.banque-centrale.dj/",
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
