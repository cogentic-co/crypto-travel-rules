{
  "countryCode": "FR",
  "name": "France",
  "authority": "Autorité des marchés financiers (AMF)",
  "rules": [
    {
      "versionId": "FR-2024-001",
      "status": "active",
      "effectiveFrom": "2024-12-30",
      "effectiveTo": "2026-06-30",
      "threshold": {
        "amount": 1000,
        "currency": "EUR",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": ["fullName", "accountNumber", "address"],
        "beneficiary": ["fullName", "accountNumber"]
      },
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "AMF-registered DASPs (Digital Asset Service Providers) must comply with EU TFR. PSAN (Prestataire de Services sur Actifs Numériques) registration required."
      },
      "authorityUrl": "https://www.amf-france.org/en/professionals/fintech/my-relations-amf/digital-asset-service-providers"
    },
    {
      "versionId": "FR-2026-001",
      "status": "pending",
      "effectiveFrom": "2026-07-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 0,
        "currency": "EUR",
        "isZeroThreshold": true
      },
      "requiredFields": {
        "originator": ["fullName", "accountNumber", "address", "dateOfBirth", "placeOfBirth", "idDocumentNumber"],
        "beneficiary": ["fullName", "accountNumber"]
      },
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "Full EU TFR enforcement. MiCA-licensed CASPs replace PSAN registration. Zero threshold for all CASP-to-CASP transfers."
      },
      "authorityUrl": "https://www.amf-france.org/en/professionals/fintech/my-relations-amf/digital-asset-service-providers"
    }
  ]
}
