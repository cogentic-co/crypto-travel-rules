{
  "countryCode": "CY",
  "name": "Cyprus",
  "authority": "Cyprus Securities and Exchange Commission (CySEC)",
  "rules": [
    {
      "versionId": "CY-2024-001",
      "status": "active",
      "effectiveFrom": "2024-12-30",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "CySEC enforces EU TFR. Cyprus is an active crypto hub in the EU."
      },
      "authorityUrl": "https://www.cysec.gov.cy/",
      "threshold": {
        "amount": 0,
        "currency": "EUR",
        "isZeroThreshold": true
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address",
          "dateOfBirth",
          "placeOfBirth",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "notes": "EU TFR (Regulation 2023/1113, .europa.eu/eli/reg/2023/1113/oj/eng) applies zero threshold to all CASP-to-CASP crypto transfers from December 30, 2024 (Art. 38). Originator must provide name, account number, and one of: address + official document number + customer ID, OR date and place of birth (Art. 14(1)(d) — alternatives, not all mandatory simultaneously). EBA Q&A 2024_6969 addresses interpretation of the 'or alternatively' clause.",
      "sources": [
        {
          "label": "EU TFR - Regulation 2023/1113",
          "url": "https://eur-lex.europa.eu/eli/reg/2023/1113/oj/eng"
        },
        {
          "label": "EBA Travel Rule Guidelines",
          "url": "https://www.eba.europa.eu/activities/single-rulebook/regulatory-activities/anti-money-laundering-and-countering-financing-terrorism/guidelines-information-requirements-relation-transfers-funds-and-certain-crypto-assets-transfers"
        }
      ]
    }
  ]
}
