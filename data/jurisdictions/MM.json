{
  "countryCode": "MM",
  "name": "Myanmar",
  "authority": "Central Bank of Myanmar",
  "rules": [
    {
      "versionId": "MM-2025-001",
      "status": "active",
      "effectiveFrom": "2025-01-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "Central Bank has not authorized cryptocurrency transactions. AML/CFT law applies to any detected activity."
      },
      "authorityUrl": "https://www.cbm.gov.mm/",
      "sources": [
        { "label": "Anti-Money Laundering Law (2014, amended) - Myanmar", "url": "https://www.cbm.gov.mm/" },
        { "label": "FATF Statement on Myanmar (High-Risk Jurisdictions)", "url": "https://www.fatf-gafi.org/en/countries/detail/Myanmar.html" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
