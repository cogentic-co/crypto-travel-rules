{
  "countryCode": "GG",
  "name": "Guernsey",
  "authority": "Guernsey Financial Services Commission (GFSC)",
  "rules": [
    {
      "versionId": "GG-2024-001",
      "status": "active",
      "effectiveFrom": "2024-01-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "GFSC registers virtual asset service providers. AML/CFT Handbook applies."
      },
      "authorityUrl": "https://www.gfsc.gg/",
      "sources": [
        { "label": "GFSC AML/CFT/CPF Handbook", "url": "https://www.gfsc.gg/commission/policy-and-legislation/amlcftcpf-handbook" },
        { "label": "Regulation of Virtual Asset Service Providers (Bailiwick of Guernsey)", "url": "https://www.gfsc.gg/industry-sectors/virtual-assets" },
        { "label": "MONEYVAL – Guernsey Mutual Evaluation", "url": "https://www.coe.int/en/web/moneyval/jurisdictions/guernsey" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "GBP",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
