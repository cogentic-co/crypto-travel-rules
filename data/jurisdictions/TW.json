{
  "countryCode": "TW",
  "name": "Taiwan",
  "authority": "Financial Supervisory Commission (FSC)",
  "rules": [
    {
      "versionId": "TW-2024-001",
      "status": "active",
      "effectiveFrom": "2024-11-30",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 30000,
        "notes": "FSC requires VASPs to register and comply with AML/CFT travel rule. Threshold aligned with FATF recommendation (approximately USD/EUR 1,000 equivalent)."
      },
      "authorityUrl": "https://www.fsc.gov.tw/en/",
      "sources": [
        { "label": "FSC Guidelines Governing Anti-Money Laundering for Virtual Currency Platforms (Taiwan)", "url": "https://www.fsc.gov.tw/en/" },
        { "label": "Money Laundering Control Act (Taiwan)", "url": "https://law.moj.gov.tw/ENG/LawClass/LawAll.aspx?pcode=G0380131" },
        { "label": "FATF - Taiwan (APG Mutual Evaluation of Chinese Taipei)", "url": "https://www.apgml.org/" }
      ],
      "threshold": {
        "amount": 30000,
        "currency": "TWD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
