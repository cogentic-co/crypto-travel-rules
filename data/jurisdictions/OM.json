{
  "countryCode": "OM",
  "name": "Oman",
  "authority": "Capital Market Authority of Oman (CMA)",
  "rules": [
    {
      "versionId": "OM-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "CMA developing virtual asset regulatory framework. AML/CFT law applies. Threshold in OMR."
      },
      "authorityUrl": "https://www.cma.gov.om/",
      "sources": [
        { "label": "Anti-Money Laundering and Combating the Financing of Terrorism Law (Royal Decree 30/2016, Oman)", "url": "https://www.cma.gov.om/" },
        { "label": "FATF - Oman (MENAFATF Mutual Evaluation)", "url": "https://www.fatf-gafi.org/en/countries/detail/Oman.html" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "OMR",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
