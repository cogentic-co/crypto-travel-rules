{
  "countryCode": "NG",
  "name": "Nigeria",
  "authority": "Securities and Exchange Commission Nigeria (SEC)",
  "rules": [
    {
      "versionId": "NG-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 1500000,
        "currency": "NGN",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": ["fullName", "accountNumber", "idDocumentNumber"],
        "beneficiary": ["fullName", "accountNumber"]
      },
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "SEC Nigeria requires licensed VASPs to comply with travel rule obligations. BVN (Bank Verification Number) or NIN required for Nigerian originators. Unhosted wallet specific rules still under development."
      },
      "authorityUrl": "https://sec.gov.ng/digital-assets/"
    }
  ]
}
