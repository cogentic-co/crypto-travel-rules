{
  "countryCode": "JP",
  "name": "Japan",
  "authority": "Japan Financial Services Agency (JFSA)",
  "rules": [
    {
      "versionId": "JP-2023-001",
      "status": "active",
      "effectiveFrom": "2023-06-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 0,
        "currency": "JPY",
        "isZeroThreshold": true
      },
      "requiredFields": {
        "originator": ["fullName", "accountNumber", "address"],
        "beneficiary": ["fullName", "accountNumber"]
      },
      "unhostedWallets": {
        "verificationRequired": true,
        "notes": "Japan was among the first to enforce the travel rule for crypto. All VASP-to-VASP transfers require originator/beneficiary data regardless of amount. Transfers to unhosted wallets require additional risk-based verification."
      },
      "authorityUrl": "https://www.fsa.go.jp/en/policy/virtual-currency/"
    }
  ]
}
