{
  "countryCode": "AD",
  "name": "Andorra",
  "authority": "Andorran Financial Authority (AFA)",
  "rules": [
    {
      "versionId": "AD-2025-001",
      "status": "active",
      "effectiveFrom": "2025-01-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "AFA regulates digital asset service providers. Aligned with EU TFR principles."
      },
      "authorityUrl": "https://www.afa.ad/en/",
      "sources": [
        { "label": "Andorra Law 14/2017 on AML/CFT", "url": "https://www.afa.ad/en/" },
        { "label": "FATF – Andorra Mutual Evaluation", "url": "https://www.fatf-gafi.org/en/countries/detail/Andorra.html" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "EUR",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
