{
  "countryCode": "CF",
  "name": "Central African Republic",
  "authority": "BEAC (Bank of Central African States)",
  "rules": [
    {
      "versionId": "CF-2022-001",
      "status": "active",
      "effectiveFrom": "2024-01-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 1000,
        "currency": "XAF",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "CAR adopted Bitcoin as legal tender (2022) but BEAC/CEMAC pushed back and implementation remains limited. BEAC regional AML framework applies uniformly across CEMAC zone. Threshold aligned with CEMAC peers."
      },
      "authorityUrl": "https://www.beac.int/"
    }
  ]
}
