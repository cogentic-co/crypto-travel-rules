              "fullName",
              "accountNumber"
            ]
          }
        },
        "verification": {
          "amount": 1000,
          "currency": "USD",
          "isZeroThreshold": false,
          "requiredFields": {
            "originator": [
              "fullName",
              "accountNumber",
              "idDocumentNumber"
            ],
            "beneficiary": [
              "fullName",
              "accountNumber"
            ]
          }
        }
      }
    }
  ]
