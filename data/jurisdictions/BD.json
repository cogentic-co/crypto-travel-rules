      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "Bangladesh Bank has not authorized cryptocurrency transactions. AML framework applies to any permitted virtual asset activity."
      },
      "authorityUrl": "https://www.bb.org.bd/",
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
