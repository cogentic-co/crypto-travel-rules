          "accountNumber",
          "address"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "sources": [
        { "label": "Financial Services Authority Seychelles — Digital Asset Business Regulations", "url": "https://www.fsaseychelles.sc/" },
