{
  "countryCode": "KY",
  "name": "Cayman Islands",
  "authority": "Cayman Islands Monetary Authority (CIMA)",
  "rules": [
    {
      "versionId": "KY-2024-001",
      "status": "active",
      "effectiveFrom": "2024-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": true,
        "verificationThreshold": 1000,
        "notes": "VASP Act 2020 and CIMA rules require registered VASPs to comply with AML Regulations travel rule. Threshold denominated in USD equivalent."
      },
      "authorityUrl": "https://www.cima.ky/virtual-asset-service-providers",
      "threshold": {
        "transmission": {
          "amount": 1000,
          "currency": "USD",
          "isZeroThreshold": false,
          "requiredFields": {
            "originator": [
              "fullName",
              "accountNumber",
              "address"
            ],
            "beneficiary": [
              "fullName",
              "accountNumber"
            ]
          }
        },
        "verification": {
          "amount": 1000,
          "currency": "USD",
          "isZeroThreshold": false,
          "requiredFields": {
            "originator": [
              "fullName",
              "accountNumber",
              "address"
            ],
            "beneficiary": [
              "fullName",
              "accountNumber"
            ]
          }
        }
      }
    }
  ]
}
