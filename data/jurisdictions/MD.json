{
  "countryCode": "MD",
  "name": "Moldova",
  "authority": "National Bank of Moldova",
  "rules": [
    {
      "versionId": "MD-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "National Bank AML/CFT framework applies. Limited crypto-specific regulation. Threshold in USD equivalent."
      },
      "authorityUrl": "https://www.bnm.md/en/",
      "sources": [
        { "label": "Moldova Law on Prevention and Combating Money Laundering and Terrorism Financing", "url": "https://www.bnm.md/en/" },
        { "label": "MONEYVAL – Moldova Mutual Evaluation", "url": "https://www.coe.int/en/web/moneyval/jurisdictions/republic-of-moldova" }
      ],
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      }
    }
  ]
}
