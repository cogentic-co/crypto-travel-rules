{
  "name": "@cogentic-co/crypto-travel-rules",
  "version": "0.3.1",
  "description": "Machine-readable directory of global crypto Travel Rule requirements with a TypeScript SDK to handle the Sunrise Issue.",
  "main": "dist/engine.js",
  "types": "dist/engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/engine.d.ts",
      "require": "./dist/engine.js",
      "import": "./dist/engine.js"
    }
  },
  "files": [
    "dist/",
    "data/jurisdictions/",
    "data/beneficiary-obligations/",
    "data/reporting/"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "validate": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run validate && npm run test && npm run build",
    "example": "npx ts-node examples/evaluate-transfer.ts",
    "generate:directory": "npx ts-node scripts/generate-directory.ts",
    "validate:data": "npx ts-node scripts/validate-jurisdictions.ts"
  },
  "keywords": [
    "crypto",
    "travel-rule",
    "FATF",
    "IVMS101",
    "compliance",
    "AML",
    "CFT",
    "VASP",
    "unhosted-wallet"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cogentic-co/crypto-travel-rules.git"
  },
  "homepage": "https://github.com/cogentic-co/crypto-travel-rules#readme",
  "bugs": {
    "url": "https://github.com/cogentic-co/crypto-travel-rules/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  }
}
