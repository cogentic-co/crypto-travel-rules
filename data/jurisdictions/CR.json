{
  "countryCode": "CR",
  "name": "Costa Rica",
  "authority": "Superintendencia General de Entidades Financieras (SUGEF)",
  "rules": [
    {
      "versionId": "CR-2025-001",
      "status": "active",
      "effectiveFrom": "2025-06-01",
      "effectiveTo": null,
      "threshold": {
        "amount": 1000,
        "currency": "USD",
        "isZeroThreshold": false
      },
      "requiredFields": {
        "originator": [
          "fullName",
          "accountNumber",
          "idDocumentNumber"
        ],
        "beneficiary": [
          "fullName",
          "accountNumber"
        ]
      },
      "unhostedWallets": {
        "verificationRequired": false,
        "notes": "SUGEF AML framework applies. Central Bank has not specifically regulated crypto."
      },
      "authorityUrl": "https://www.sugef.fi.cr/"
    }
  ]
}
